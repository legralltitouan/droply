<Application x:Class="QuikSend.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QuikSend"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="AppControlBgBrush" Color="#222222"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="AppTextBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="AppSubTextBrush" Color="#8A8A8A"/>
            <SolidColorBrush x:Key="AppHoverBrush" Color="#353535"/>
        </Application.Resources>
</Application>
