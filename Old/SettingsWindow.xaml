<Window x:Class="QuickSend.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres du Système" Height="590" Width="490"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FluentToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Track" Width="42" Height="22" CornerRadius="11" Background="{DynamicResource AppBorderBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" SnapsToDevicePixels="True">
                                <Grid>
                                    <Border x:Name="ActiveTrack" Background="#ED8209" CornerRadius="10" Opacity="0"/>
                                    <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="{DynamicResource AppSubTextBrush}" HorizontalAlignment="Left" Margin="3,0,0,0" SnapsToDevicePixels="True">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.2" DecelerationRatio="0.8"/>
                                            <DoubleAnimation Storyboard.TargetName="ActiveTrack" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2" DecelerationRatio="0.8"/>
                                            <DoubleAnimation Storyboard.TargetName="ActiveTrack" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="HoverLayer" Background="{DynamicResource AppHoverBrush}" CornerRadius="5" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#ED8209"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="HoverLayer" Background="#FF981A" CornerRadius="6" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                    <DoubleAnimation Storyboard.TargetName="WindowTransform" Storyboard.TargetProperty="Y" From="35" To="0" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.15"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="MainBorder" Margin="45" Background="{DynamicResource AppBgBrush}" CornerRadius="10" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
        <Border.RenderTransform>
            <TranslateTransform x:Name="WindowTransform" Y="0"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="85" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" x:Name="TitleBar" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="⚙" Foreground="#ED8209" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Paramètres du Système" FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="32" Height="32" Click="Close_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="HoverCircle" Fill="{DynamicResource AppHoverBrush}" Opacity="0" />
                                            <TextBlock Text="✕" FontSize="14" Foreground="{DynamicResource AppSubTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" x:Name="CloseIcon"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                                <Setter TargetName="CloseIcon" Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="15,5,15,10">

                    <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8" Padding="15,12" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="38" Height="38">
                                <Ellipse Fill="{DynamicResource AppBgBrush}"/>
                                <TextBlock Text="U" Foreground="#ED8209" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                            </Grid>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Utilisateur" FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Compte Local • En ligne" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="PRÉFÉRENCES GÉNÉRALES" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8" Padding="15,5" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                        <StackPanel>
                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" Background="{DynamicResource AppBgBrush}" CornerRadius="6">
                                    <TextBlock Text="🚀" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Lancer au démarrage" FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="Ouvrir l'application à la connexion" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" x:Name="StartupCheck" Style="{StaticResource FluentToggleSwitch}" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AppBorderBrush}"/>

                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" Background="{DynamicResource AppBgBrush}" CornerRadius="6">
                                    <TextBlock Text="☀️" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Mode Clair" FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="Utiliser le thème lumineux" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" x:Name="ThemeCheck" Style="{StaticResource FluentToggleSwitch}" VerticalAlignment="Center" Click="ThemeCheck_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DISCORD WEBHOOK (OPTIONNEL)" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource AppBgBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                        <TextBox x:Name="WebhookBox" Background="Transparent" Foreground="{DynamicResource AppTextBrush}" BorderThickness="0" Padding="10,7" FontSize="12" SelectionBrush="#ED8209" CaretBrush="{DynamicResource AppTextBrush}"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                        <TextBlock Text="ⓘ" Foreground="#ED8209" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Copiez l'URL du salon Webhook pour les notifications" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Background="Transparent" Margin="15,0,15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Annuler" Style="{StaticResource SecondaryButton}" Width="85" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button Style="{StaticResource PrimaryButton}" Width="165" Height="30" Click="SaveAndClose_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="11" Margin="0,1,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Enregistrer &amp; Fermer" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
