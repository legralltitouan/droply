<Window x:Class="QuickSend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Droply" Height="65" Width="180"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave">

    <Window.Resources>
        <Style x:Key="FluentContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="8">
                            <StackPanel IsItemsHost="True" Margin="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="DropBorder" CornerRadius="6" BorderThickness="1" Margin="10" Height="42" Width="42" HorizontalAlignment="Left">
        <Border.ContextMenu>
            <ContextMenu Style="{StaticResource FluentContextMenu}">
                <MenuItem Header="Paramètres" Style="{StaticResource FluentMenuItem}" Click="OpenSettings_Click"/>
                <MenuItem Header="Quitter" Style="{StaticResource FluentMenuItem}" Click="Quit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.35" Direction="270"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible"/>
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Effect" Value="{x:Null}"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid x:Name="IdleState" Background="Transparent" Opacity="1" Visibility="Visible">
                <Image Source="logo.png" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <Grid x:Name="UploadState" Visibility="Collapsed" Opacity="0" Margin="8,0,8,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Uploading..." FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="6" BorderThickness="0" Background="Transparent">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="3"/>
                                    <Border x:Name="PART_Track" CornerRadius="3">
                                        <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                            <Border CornerRadius="3">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#FFE6BB8D" Offset="0.0"/>
                                                        <GradientStop Color="#FFED8209" Offset="0.26"/>
                                                        <GradientStop Color="#FFED8209" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </StackPanel>
            </Grid>

            <Grid x:Name="SuccessState" Visibility="Collapsed" Opacity="0" Margin="3">
                <Grid>
                    <Border CornerRadius="6">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FFE6BB8D" Offset="0.0"/>
                                <GradientStop Color="#FFED8209" Offset="0.26"/>
                                <GradientStop Color="#FFED8209" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <TextBlock Text="Copied" FontFamily="Segoe UI" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <Grid x:Name="ErrorState" Visibility="Collapsed" Opacity="0" Margin="3">
                <Border Background="#E81123" CornerRadius="6">
                    <TextBlock x:Name="ErrorText" Text="Failed" FontFamily="Segoe UI" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
