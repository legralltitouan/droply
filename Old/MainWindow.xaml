<Window x:Class="QuickSend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Droply" Height="65" Width="180"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave">

    <Border x:Name="DropBorder" CornerRadius="8" BorderThickness="1" Margin="10" Height="42" Width="42" HorizontalAlignment="Left">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#2A2C31"/>
                <Setter Property="BorderBrush" Value="#3E4047"/>

                <Style.Triggers>
                    <DataTrigger Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </DataTrigger>

                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible"/>
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#36373750"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.35" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid x:Name="IdleState" Background="Transparent">
                <Image Source="logo.png" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <Grid x:Name="UploadState" Visibility="Collapsed" Margin="8,0,8,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Uploading..." FontFamily="Segoe UI" Foreground="#FFF4C7A3" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="6" BorderThickness="0" Background="Transparent">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border Background="#1C1D21" CornerRadius="3"/>
                                    <Border x:Name="PART_Track" CornerRadius="3">
                                        <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                            <Border CornerRadius="3">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#FFE6BB8D" Offset="0.0"/>
                                                        <GradientStop Color="#FFED8209" Offset="0.26"/>
                                                        <GradientStop Color="#FFED8209" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border CornerRadius="3" Opacity="0.6">
                                                <Border.Background>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#FFE05201" Offset="0.14"/>
                                                        <GradientStop Color="#00509DF5" Offset="0.83"/>
                                                    </RadialGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border CornerRadius="3" Opacity="0.1">
                                                <Border.Background>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#00E05301" Offset="0.28"/>
                                                        <GradientStop Color="#FFE05500" Offset="1.0"/>
                                                    </RadialGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </StackPanel>
            </Grid>

            <Grid x:Name="SuccessState" Visibility="Collapsed" Margin="3">
                <Grid>
                    <Border CornerRadius="6">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FFE6BB8D" Offset="0.0"/>
                                <GradientStop Color="#FFED8209" Offset="0.26"/>
                                <GradientStop Color="#FFED8209" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="6" Opacity="0.6">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFE05201" Offset="0.14"/>
                                <GradientStop Color="#00509DF5" Offset="0.83"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="6" Opacity="0.1">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#00E05301" Offset="0.28"/>
                                <GradientStop Color="#FFE05500" Offset="1.0"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <TextBlock Text="Copied" FontFamily="Segoe UI" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <Grid x:Name="ErrorState" Visibility="Collapsed" Margin="3">
                <Border Background="#E81123" CornerRadius="6">
                    <TextBlock x:Name="ErrorText" Text="Failed" FontFamily="Segoe UI" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
