<!--
  ============================================================================
  Droply - MainWindow.xaml
  Pastille flottante posée sur la barre des tâches.
  - Taille fixe 180x65 (la pastille interne s'étire dynamiquement).
  - Sans bordure, transparente, toujours au premier plan.
  - Réceptionne les Drag&Drop de fichiers.
  - Tous les textes utilisent {DynamicResource L.*} pour le live-switch FR/EN.
  - Toutes les couleurs utilisent {DynamicResource App*Brush} pour le live-switch
    thème clair/sombre.
  ============================================================================
-->
<Window x:Class="Droply.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Droply" Height="65" Width="180"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave">

    <Window.Resources>
        <!-- Styles du menu contextuel "Fluent" (clic droit sur la pastille) -->
        <Style x:Key="FluentContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <StackPanel IsItemsHost="True" Margin="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Conteneur principal : la "pastille" qui change d'état (Idle / Upload /
         Success / Error). Sa Width est animée dans le code-behind. -->
    <Border x:Name="DropBorder" CornerRadius="6" BorderThickness="1" Margin="10" Height="42" Width="42" HorizontalAlignment="Left">
        <Border.ContextMenu>
            <ContextMenu Style="{StaticResource FluentContextMenu}">
                <MenuItem Header="{DynamicResource L.Menu.Settings}" Style="{StaticResource FluentMenuItem}" Click="OpenSettings_Click"/>
                <MenuItem Header="{DynamicResource L.Menu.Quit}"     Style="{StaticResource FluentMenuItem}" Click="Quit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <!-- Style local : transparent en idle, opaque (couleur de thème) sinon. -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource AppBgBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.35" Direction="270"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- État Idle : pastille invisible (logo seul) -->
                    <DataTrigger Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </DataTrigger>
                    <!-- Idle + survol souris : léger fond hover -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible"/>
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background"  Value="{DynamicResource AppHoverBrush}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Effect"      Value="{x:Null}"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- État 1 : repos (logo) -->
            <Grid x:Name="IdleState" Background="Transparent" Opacity="1" Visibility="Visible">
                <Image Source="logo.png" Width="22" Height="22" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <!-- État 2 : upload en cours (texte + barre de progression dégradée) -->
            <Grid x:Name="UploadState" Visibility="Collapsed" Opacity="0" Margin="8,0,8,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource L.State.Uploading}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="6"
                                 BorderThickness="0" Background="Transparent">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="3"/>
                                    <Border x:Name="PART_Track" CornerRadius="3">
                                        <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                            <Border CornerRadius="3">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#FFE6BB8D" Offset="0.0"/>
                                                        <GradientStop Color="#FFED8209" Offset="0.26"/>
                                                        <GradientStop Color="#FFED8209" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </StackPanel>
            </Grid>

            <!-- État 3 : succès (lien copié dans le presse-papier) -->
            <Grid x:Name="SuccessState" Visibility="Collapsed" Opacity="0" Margin="3">
                <Grid>
                    <Border CornerRadius="6">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FFE6BB8D" Offset="0.0"/>
                                <GradientStop Color="#FFED8209" Offset="0.26"/>
                                <GradientStop Color="#FFED8209" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <TextBlock Text="{DynamicResource L.State.Copied}" FontFamily="Segoe UI"
                           Foreground="White" FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- État 4 : erreur -->
            <Grid x:Name="ErrorState" Visibility="Collapsed" Opacity="0" Margin="3">
                <Border Background="#E81123" CornerRadius="6">
                    <TextBlock x:Name="ErrorText" Text="Failed" FontFamily="Segoe UI"
                               Foreground="White" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>