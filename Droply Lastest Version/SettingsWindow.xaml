<!--
  ============================================================================
  Droply - SettingsWindow.xaml
  Fenêtre de paramètres (modale "flottante") :
   - Démarrage Windows (toggle)
   - Thème clair/sombre (toggle, live-preview)
   - Langue FR/EN (toggle, live-preview via Localization.ApplyLanguage)
   - Webhook Discord (notification d'upload)
   - Token bot Discord + ChannelId (sync cross-PC)
  Tous les libellés passent par {DynamicResource L.*}, toutes les couleurs par
  {DynamicResource App*Brush}, ce qui permet un changement de langue / thème
  sans recharger la fenêtre.
  ============================================================================
-->
<Window x:Class="Droply.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres du Système" Height="590" Width="490"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ============= Toggle switch animé (style iOS / Fluent) ============= -->
        <Style x:Key="FluentToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Track" Width="42" Height="22" CornerRadius="11"
                                    Background="{DynamicResource AppBorderBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1" SnapsToDevicePixels="True">
                                <Grid>
                                    <Border x:Name="ActiveTrack" Background="#ED8209" CornerRadius="10" Opacity="0"/>
                                    <Ellipse x:Name="Thumb" Width="14" Height="14"
                                             Fill="{DynamicResource AppSubTextBrush}"
                                             HorizontalAlignment="Left" Margin="3,0,0,0"
                                             SnapsToDevicePixels="True">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.2" DecelerationRatio="0.8"/>
                                            <DoubleAnimation Storyboard.TargetName="ActiveTrack"    Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2" DecelerationRatio="0.8"/>
                                            <DoubleAnimation Storyboard.TargetName="ActiveTrack"    Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============= Bouton secondaire (Annuler) ============= -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AppControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="HoverLayer" Background="{DynamicResource AppHoverBrush}" CornerRadius="5" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============= Bouton principal (Enregistrer) ============= -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#ED8209"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="HoverLayer" Background="#FF981A" CornerRadius="6" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverLayer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============= Barre de défilement personnalisée ============= -->
        <Style x:Key="DroplyScrollBar" TargetType="ScrollBar">
            <Setter Property="Width"      Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4" Background="{DynamicResource AppBorderBrush}" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer global utilisant la ScrollBar personnalisée -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource DroplyScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Animation d'ouverture : fondu + petit glissement vertical -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="WindowTransform"
                             Storyboard.TargetProperty="Y" From="40" To="0" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.25"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.96" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.96" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- Carte principale (bord arrondi + ombre portée) -->
    <Border x:Name="MainBorder" Margin="45"
            RenderTransformOrigin="0.5,0.5"
            Background="{DynamicResource AppBgBrush}" CornerRadius="10"
            BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="WindowTransform" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="85" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <!-- Barre de titre -->
                <RowDefinition Height="*"/>
                <!-- Contenu défilable -->
                <RowDefinition Height="65"/>
                <!-- Boutons d'action -->
            </Grid.RowDefinitions>

            <!-- ===== Barre de titre (drag + bouton fermer) ===== -->
            <Grid Grid.Row="0" Background="Transparent" x:Name="TitleBar" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="⚙" Foreground="#ED8209" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource L.Settings.Title}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppTextBrush}" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,10,0" Width="32" Height="32" Click="Close_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="HoverCircle" Fill="{DynamicResource AppHoverBrush}" Opacity="0"/>
                                            <TextBlock x:Name="CloseIcon" Text="✕" FontSize="14"
                                                       Foreground="{DynamicResource AppSubTextBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,-1,0,0"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverCircle" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                                <Setter TargetName="CloseIcon" Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ===== Contenu défilable ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <StackPanel x:Name="MainPanel"  Margin="15,5,15,10" Opacity="1">

                        <!-- ===== Carte d'accès aux Statistiques ===== -->
                    <Button x:Name="StatsCardBtn" Click="OpenStats_Click" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalContentAlignment="Stretch" Margin="0,0,0,20">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{DynamicResource AppControlBgBrush}"
                                        CornerRadius="8" Padding="15,12"
                                        BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="38" Height="38">
                                <Ellipse Fill="{DynamicResource AppBgBrush}"/>
                                <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource L.Settings.Stats}"
                                           FontFamily="Segoe UI"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource L.Settings.StatsHint}"
                                           FontFamily="Segoe UI"
                                           Foreground="{DynamicResource AppSubTextBrush}"
                                           FontSize="11" Margin="0,1,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" FontSize="22"
                                       Foreground="{DynamicResource AppSubTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                        </Grid>
                    </Button>

                    <!-- ===== Section Général : démarrage / thème / langue ===== -->
                    <TextBlock Text="{DynamicResource L.Settings.SectionGeneral}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppSubTextBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8" Padding="15,5"
                            Margin="0,0,0,20" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                        <StackPanel>
                            <!-- Démarrage Windows -->
                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" Background="{DynamicResource AppBgBrush}" CornerRadius="6">
                                    <TextBlock Text="🚀" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource L.Settings.Startup}"     FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}"    FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource L.Settings.StartupHint}" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11"   Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" x:Name="StartupCheck" Style="{StaticResource FluentToggleSwitch}" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AppBorderBrush}"/>

                            <!-- Thème clair / sombre (live preview) -->
                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" Background="{DynamicResource AppBgBrush}" CornerRadius="6">
                                    <TextBlock Text="☀️" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource L.Settings.LightMode}"     FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}"    FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource L.Settings.LightModeHint}" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11"   Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" x:Name="ThemeCheck" Style="{StaticResource FluentToggleSwitch}" VerticalAlignment="Center" Click="ThemeCheck_Click"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource AppBorderBrush}"/>

                            <!-- Langue FR / EN (live preview) -->
                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" Background="{DynamicResource AppBgBrush}" CornerRadius="6">
                                    <TextBlock Text="🌐" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource L.Settings.Language}"     FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}"    FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource L.Settings.LanguageHint}" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11"   Margin="0,1,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" x:Name="LanguageCheck" Style="{StaticResource FluentToggleSwitch}" VerticalAlignment="Center" Click="LanguageCheck_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ===== Section Webhook Discord ===== -->
                    <TextBlock Text="{DynamicResource L.Settings.SectionWebhook}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppSubTextBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource FocusableField}" Margin="0,0,0,8">
                            <TextBox x:Name="WebhookBox" Style="{StaticResource AnimatedTextBox}"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                        <TextBlock Text="ⓘ" Foreground="#ED8209" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L.Settings.WebhookHint}" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ===== Section Sync Discord cross-PC (bot + channel) ===== -->
                    <TextBlock Text="{DynamicResource L.Settings.SectionDiscord}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppSubTextBrush}" FontSize="10.5" FontWeight="Bold" Margin="0,15,0,8"/>

                    <TextBlock Text="{DynamicResource L.Settings.BotToken}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" Margin="2,0,0,4"/>
                        <Border Style="{StaticResource FocusableField}" Margin="0,0,0,8">
                            <TextBox x:Name="BotTokenBox" Style="{StaticResource AnimatedTextBox}"/>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Settings.ChannelId}" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" Margin="2,0,0,4"/>
                        <Border Style="{StaticResource FocusableField}" Margin="0,0,0,8">
                            <TextBox x:Name="ChannelIdBox" Style="{StaticResource AnimatedTextBox}"/>
                        </Border>
                    </StackPanel>

                    <!-- ============ Page Statistiques ============ -->
                    <StackPanel x:Name="StatsPanel" Margin="15,5,15,10" Visibility="Collapsed" Opacity="0">
                        <Button Content="{DynamicResource L.Settings.StatsBack}"
                                Style="{StaticResource GhostButton}"
                                Click="BackFromStats_Click"
                                HorizontalAlignment="Left" Margin="-4,0,0,12"/>

                        <TextBlock Text="{DynamicResource L.Stats.Title}"
                               FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,15"/>

                        <!-- Carte : Nom du PC -->
                        <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8"
                            Padding="15,12" Margin="0,0,0,10" BorderThickness="1"
                            BorderBrush="{DynamicResource AppBorderBrush}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Stats.PcName}"
                                       Foreground="{DynamicResource AppSubTextBrush}" FontSize="11"/>
                                <TextBlock x:Name="StatPcName" Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte : Total transféré -->
                        <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8"
                            Padding="15,12" Margin="0,0,0,10" BorderThickness="1"
                            BorderBrush="{DynamicResource AppBorderBrush}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Stats.TotalTransferred}"
                                       Foreground="{DynamicResource AppSubTextBrush}" FontSize="11"/>
                                <TextBlock x:Name="StatTotal" Foreground="#ED8209"
                                       FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte : Envoyé aujourd'hui -->
                        <Border Background="{DynamicResource AppControlBgBrush}" CornerRadius="8"
                            Padding="15,12" Margin="0,0,0,10" BorderThickness="1"
                            BorderBrush="{DynamicResource AppBorderBrush}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Stats.SentToday}"
                                       Foreground="{DynamicResource AppSubTextBrush}" FontSize="11"/>
                                <TextBlock x:Name="StatToday" Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- ===== Pied de page : Annuler / Enregistrer ===== -->
            <Grid Grid.Row="2" Background="Transparent" Margin="15,0,15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{DynamicResource L.Settings.Cancel}"
        Style="{StaticResource AnimatedSecondaryButton}"
        Width="85" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>

                    <Button Style="{StaticResource AnimatedPrimaryButton}"
        Width="165" Height="30" Click="SaveAndClose_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="11" Margin="0,1,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource L.Settings.Save}" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>