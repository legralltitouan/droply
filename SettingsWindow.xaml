<Window x:Class="QuickSend.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Droply Settings" Height="260" Width="240"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen">

    <Border Background="{DynamicResource AppBgBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5" Direction="270"/>
        </Border.Effect>
        <StackPanel Margin="15">
            <TextBlock Text="PARAMÈTRES" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>

            <CheckBox x:Name="StartupCheck" Content="Lancer au démarrage" FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" Margin="0,5"/>
            <CheckBox x:Name="ThemeCheck" Content="Mode Clair" FontFamily="Segoe UI" Foreground="{DynamicResource AppTextBrush}" Margin="0,5" Click="ThemeCheck_Click"/>

            <Separator Background="{DynamicResource AppBorderBrush}" Margin="0,15"/>

            <TextBlock Text="DISCORD WEBHOOK (Optionnel)" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="11" FontWeight="Bold" Margin="0,5"/>
            <TextBox x:Name="WebhookBox" Background="{DynamicResource AppControlBgBrush}" Foreground="{DynamicResource AppTextBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="5" Height="26" VerticalContentAlignment="Center" Margin="0,5"/>
            <TextBlock Text="Copiez l'URL du salon Webhook" FontFamily="Segoe UI" Foreground="{DynamicResource AppSubTextBrush}" FontSize="10" Margin="0,0,0,10"/>

            <Button Content="Enregistrer &amp; Fermer" Click="SaveAndClose_Click" Margin="0,10,0,0" Height="28" Background="#FFED8209" Foreground="White" FontWeight="Bold" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>