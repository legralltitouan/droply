<Application x:Class="Droply.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Tokens compat-rétro -->
            <SolidColorBrush x:Key="AppBgBrush"        Color="{DynamicResource SolidBackgroundFillColorBase}"/>
            <SolidColorBrush x:Key="AppControlBgBrush" Color="{DynamicResource CardBackgroundFillColorDefault}"/>
            <SolidColorBrush x:Key="AppBorderBrush"    Color="{DynamicResource ControlStrokeColorDefault}"/>
            <SolidColorBrush x:Key="AppTextBrush"      Color="{DynamicResource TextFillColorPrimary}"/>
            <SolidColorBrush x:Key="AppSubTextBrush"   Color="{DynamicResource TextFillColorSecondary}"/>
            <SolidColorBrush x:Key="AppHoverBrush"     Color="{DynamicResource SubtleFillColorSecondary}"/>

            <!-- ============ Strings localisées (défauts FR) ============ -->
            <sys:String x:Key="L.Menu.Settings">Paramètres</sys:String>
            <sys:String x:Key="L.Menu.Quit">Quitter</sys:String>
            <sys:String x:Key="L.State.Uploading">Uploading...</sys:String>
            <sys:String x:Key="L.State.Copied">Copied</sys:String>
            <sys:String x:Key="L.Error.NotFound">Introuvable</sys:String>
            <sys:String x:Key="L.Error.TooLarge">Trop lourd</sys:String>
            <sys:String x:Key="L.Error.Failed">Échec</sys:String>

            <sys:String x:Key="L.Settings.Title">Paramètres du Système</sys:String>
            <sys:String x:Key="L.Settings.SectionGeneral">PRÉFÉRENCES GÉNÉRALES</sys:String>
            <sys:String x:Key="L.Settings.SectionWebhook">DISCORD WEBHOOK (OPTIONNEL)</sys:String>
            <sys:String x:Key="L.Settings.SectionDiscord">DISCORD SYNC (OPTIONNEL)</sys:String>
            <sys:String x:Key="L.Settings.Startup">Lancer au démarrage</sys:String>
            <sys:String x:Key="L.Settings.StartupHint">Ouvrir l'application à la connexion</sys:String>
            <sys:String x:Key="L.Settings.LightMode">Mode Clair</sys:String>
            <sys:String x:Key="L.Settings.LightModeHint">Utiliser le thème lumineux</sys:String>
            <sys:String x:Key="L.Settings.Language">Langue (English)</sys:String>
            <sys:String x:Key="L.Settings.LanguageHint">Basculer l'interface en anglais</sys:String>
            <sys:String x:Key="L.Settings.WebhookHint">Copiez l'URL du salon Webhook pour les notifications</sys:String>
            <sys:String x:Key="L.Settings.BotToken">Bot Token</sys:String>
            <sys:String x:Key="L.Settings.ChannelId">ID du salon</sys:String>
            <sys:String x:Key="L.Settings.Cancel">Annuler</sys:String>
            <sys:String x:Key="L.Settings.Save">Enregistrer &amp; Fermer</sys:String>
            <sys:String x:Key="L.Settings.Stats">Statistiques</sys:String>
            <sys:String x:Key="L.Settings.StatsHint">Voir l'usage Droply de ce PC</sys:String>
            <sys:String x:Key="L.Settings.StatsBack">← Retour</sys:String>

            <sys:String x:Key="L.Stats.Title">Statistiques</sys:String>
            <sys:String x:Key="L.Stats.PcName">Nom du PC</sys:String>
            <sys:String x:Key="L.Stats.TotalTransferred">Total transféré</sys:String>
            <sys:String x:Key="L.Stats.SentToday">Envoyé aujourd'hui</sys:String>

            <sys:String x:Key="L.Webhook.NewFile">📦 Nouveau fichier Droply</sys:String>
            <sys:String x:Key="L.Toast.Title">Fichier reçu depuis votre autre PC</sys:String>
            <sys:String x:Key="L.Toast.Subtitle">Un nouvel upload Droply vient d'arriver. Le télécharger ?</sys:String>
            <sys:String x:Key="L.Toast.Download">Télécharger</sys:String>
            <sys:String x:Key="L.Toast.Ignore">Ignorer</sys:String>

            <!-- ============ Alias compat (SANS BasedOn) ============ -->
            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="AnimatedSecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AnimatedPrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="AnimatedTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,7"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="FocusableField" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <Style x:Key="HoverableCard" TargetType="Border">
                <Setter Property="Background"      Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="8"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>