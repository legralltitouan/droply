<ui:FluentWindow x:Class="Droply.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Paramètres du Système"
                 Height="640" Width="540" MinHeight="500" MinWidth="460"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource L.Settings.Title}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="logo.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1"
              x:Name="SettingsScroll"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              Padding="36,16,36,16"
              CanContentScroll="False"
              PanningMode="VerticalOnly"
              PreviewMouseWheel="SettingsScroll_PreviewMouseWheel">
            <StackPanel>
                <!-- ===== Page principale ===== -->
                <StackPanel x:Name="MainPanel" RenderTransformOrigin="0.5,0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.45"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="20" To="0" Duration="0:0:0.55">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    <ui:CardAction Margin="0,0,0,24" Icon="{ui:SymbolIcon DataBarVertical24}" Click="OpenStats_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Settings.Stats}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource L.Settings.StatsHint}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </ui:CardAction>

                    <TextBlock Text="{DynamicResource L.Settings.SectionGeneral}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,10"/>

                    <ui:CardControl Margin="0,0,0,6" Icon="{ui:SymbolIcon Rocket24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Settings.Startup}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource L.Settings.StartupHint}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="StartupCheck"/>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,6" Icon="{ui:SymbolIcon WeatherSunny24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Settings.LightMode}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource L.Settings.LightModeHint}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="ThemeCheck" Click="ThemeCheck_Click"/>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,0,0,24" Icon="{ui:SymbolIcon LocalLanguage24}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource L.Settings.Language}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource L.Settings.LanguageHint}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch x:Name="LanguageCheck" Click="LanguageCheck_Click"/>
                    </ui:CardControl>

                    <TextBlock Text="{DynamicResource L.Settings.SectionWebhook}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,10"/>
                    <ui:TextBox x:Name="WebhookBox" PlaceholderText="https://discord.com/api/webhooks/..."
                                Margin="0,0,0,8" Icon="{ui:SymbolIcon Link24}"/>
                    <TextBlock Text="{DynamicResource L.Settings.WebhookHint}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="2,0,0,24"/>

                    <TextBlock Text="{DynamicResource L.Settings.SectionDiscord}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource L.Settings.BotToken}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="2,0,0,4"/>
                    <ui:PasswordBox x:Name="BotTokenBox" PlaceholderText="MTI..."
                                    Margin="0,0,0,12" RevealButtonEnabled="True" Icon="{ui:SymbolIcon Key24}"/>
                    <TextBlock Text="{DynamicResource L.Settings.ChannelId}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="2,0,0,4"/>
                    <ui:TextBox x:Name="ChannelIdBox" PlaceholderText="1234567890..."
                                Margin="0,0,0,20" Icon="{ui:SymbolIcon Channel24}"/>
                </StackPanel>

                <!-- ===== Page Stats ===== -->
                <StackPanel x:Name="StatsPanel" Visibility="Collapsed" Opacity="0">
                    <ui:Button Content="{DynamicResource L.Settings.StatsBack}" Icon="{ui:SymbolIcon ArrowLeft24}"
                               Appearance="Transparent" Click="BackFromStats_Click"
                               HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource L.Stats.Title}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,18"/>
                    <ui:Card Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Stats.PcName}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="StatPcName" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Stats.TotalTransferred}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="StatTotal" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L.Stats.SentToday}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="StatToday" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Footer : dégradé subtil + séparateur haut ===== -->
        <Grid Grid.Row="2">
            <!-- Couche 1 : dégradé vertical doux (fonctionne sur Mica) -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.0"/>
                        <GradientStop Color="#22000000" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Couche 2 : séparateur haut subtil (style Win11 dialog footer) -->
            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="36,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="{DynamicResource L.Settings.Cancel}"
                       Appearance="Secondary"
                       MinWidth="100" Margin="0,0,10,0"
                       Click="Cancel_Click"/>
                    <ui:Button Content="{DynamicResource L.Settings.Save}"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Save24}"
                       MinWidth="180"
                       Click="SaveAndClose_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>