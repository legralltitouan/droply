<Window x:Class="Droply.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Droply" Height="65" Width="180"
        WindowStyle="None" AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Style>
    <Border x:Name="DropBorder" CornerRadius="8" BorderThickness="1" Margin="10"
            Height="42" Width="42" HorizontalAlignment="Left"
            MouseEnter="DropBorder_MouseEnter" MouseLeave="DropBorder_MouseLeave">
        <Border.ContextMenu>
            <ContextMenu
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        HasDropShadow="True">
                <MenuItem Header="{DynamicResource L.Menu.Settings}" Click="OpenSettings_Click">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource L.Menu.Quit}" Click="Quit_Click">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Power24"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background"  Value="{DynamicResource SolidBackgroundFillColorBaseBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="3" Opacity="0.35" Direction="270"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Effect"      Value="{x:Null}"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Visibility, ElementName=IdleState}" Value="Visible"/>
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background"  Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Popup x:Name="UploadInfoPopup" PlacementTarget="{Binding ElementName=DropBorder}"
                   Placement="Top" VerticalOffset="-6" AllowsTransparency="True"
                   StaysOpen="True" IsHitTestVisible="False">
                <Border CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.4" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock x:Name="SpeedText" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="EtaText" FontSize="11" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Popup>
            <Grid x:Name="IdleState" Background="Transparent" Opacity="1" Visibility="Visible">
                <Image Source="logo.png" Width="22" Height="22" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
            <Grid x:Name="UploadState" Visibility="Collapsed" Opacity="0" Margin="8,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource L.State.Uploading}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="6"
                                 BorderThickness="0" Background="Transparent">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="3"/>
                                    <Border x:Name="PART_Track" CornerRadius="3">
                                        <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                            <Border CornerRadius="3" Background="{DynamicResource AccentFillColorDefaultBrush}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </StackPanel>
            </Grid>
            <Grid x:Name="SuccessState" Visibility="Collapsed" Opacity="0" Margin="3">
                <Border CornerRadius="6" Background="{DynamicResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="{DynamicResource L.State.Copied}"
                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                           FontWeight="SemiBold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="ErrorState" Visibility="Collapsed" Opacity="0" Margin="3">
                <Border Background="{DynamicResource SystemFillColorCriticalBrush}" CornerRadius="6">
                    <TextBlock x:Name="ErrorText" Text="Failed" FontWeight="SemiBold"
                               Foreground="White" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>